{
  "file_types": {
    "Metal": [
      "h",
      "H"
    ]
  },
  "languages": {
    "Metal": {
      "formatter": "language_server",
      "format_on_save": "on"
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy"
        }
      }
    },
    "metal-analyzer": {
      "initialization_options": {
        "metal-analyzer": {
          "diagnostics": {
            "onType": true,
            "onSave": true,
            "debounceMs": 300,
            "scope": "workspace"
          },
          "indexing": {
            "enabled": true,
            "concurrency": 8,
            "maxFileSizeKb": 1024
          },
          "formatting": {
            "enabled": true,
            "command": "clang-format",
            "args": []
          },
          "compiler": {
            "includePaths": [],
            "extraFlags": []
          }
        }
      }
    }
  }
}