{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
  },
  "files.associations": {
    "*.h": "metal",
  },
  "rust-analyzer.rustfmt.extraArgs": [
    "+nightly"
  ],
  "[rust]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
  },
  "rust-analyzer.check.workspace": false,
  "rust-analyzer.cargo.allTargets": false,
  "rust-analyzer.check.noDefaultFeatures": true,
  "rust-analyzer.testExplorer": true,
  "rust-analyzer.cargo.buildScripts.enable": true,
  "rust-analyzer.procMacro.enable": true,
  "[metal]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "eugenebokhan.metal-analyzer",
  },
  "metal-analyzer.diagnostics.onType": true,
  "metal-analyzer.diagnostics.onSave": true,
  "metal-analyzer.diagnostics.debounceMs": 300,
  "metal-analyzer.indexing.enabled": true,
  "metal-analyzer.indexing.concurrency": 8,
  "metal-analyzer.indexing.maxFileSizeKb": 1024,
  "metal-analyzer.formatting.enabled": true,
  "metal-analyzer.formatting.command": "clang-format",
  "metal-analyzer.formatting.args": [],
  "metal-analyzer.diagnostics.scope": "workspace",
  "metal-analyzer.compiler.includePaths": [],
  "metal-analyzer.compiler.extraFlags": [],
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "python.defaultInterpreterPath": "tools/.venv/bin/python",
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": false,
  "ruff.path": [
    "tools/.venv/bin/ruff"
  ],
  "[swift]": {
    "editor.formatOnSave": true,
  },
  "[toml]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "tamasfe.even-better-toml",
  },
  "[json]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.json-language-features"
  },
}